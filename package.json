{
  "name": "Galeri",
  "productName": "Galeri",
  "version": "0.0.28",
  "author": {
    "name": "Micheal Parks",
    "email": "michealparks1989@gmail.com",
    "url": "https://www.galeri.io"
  },
  "description": "A perpetual artwork streaming app.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "cross-env NODE_ENV=production electron ./app/main",
    "dev": "cross-env NODE_ENV=development electron ./app/main"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michealparks/galeri.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/michealparks/galeri/issues"
  },
  "homepage": "https://www.galeri.io",
  "bin": {
    "electron": "./node_modules/.bin/electron"
  },
  "engines": {
    "node": ">=7.0.0",
    "npm": ">=4.0.0"
  },
  "optionalDependencies": {
    "appdmg": "^0.5.2"
  },
  "devDependencies": {
    "asar": "^0.14.3",
    "concurrently": "^3.5.1",
    "cross-env": "^5.1.4",
    "electron": "^2.0.0",
    "electron-reloader": "^0.2.0"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.2",
    "electron-debug": "^1.5.0",
    "request": "^2.85.0",
    "wallpaper": "^3.0.0"
  },
  "standard": {
    "globals": [
      "__VERSION__",
      "__dev__",
      "__darwin__",
      "__linux__",
      "__win32__",
      "__trayIcon__",
      "__trayIconDark__",
      "Image",
      "XMLHttpRequest",
      "fetch",
      "localStorage"
    ]
  },
  "build": {
    "appId": "io.galeri.app",
    "copyright": "Copyright © 2016 - 2017 Micheal Parks",
    "productName": "Galeri",
    "files": [
      "package.json",
      "LICENSE",
      "main.js",
      "build/**/*",
      "assets"
    ],
    "compression": "maximum",
    "mac": {
      "category": "public.app-category.education"
    },
    "linux": {
      "target": [
        "deb",
        "snap"
      ],
      "category": "Education",
      "synopsis": "A perpetual artwork streaming app.",
      "desktop": {
        "Type": "Application",
        "Encoding": "UTF-8",
        "Name": "Galeri",
        "Version": "1.0",
        "X-GNOME-FullName": "Galeri",
        "Comment": "A perpetual artwork streaming app.",
        "Icon": "Galeri",
        "Terminal": "false",
        "Path": "/opt/galeri",
        "Exec": "/opt/galeri/Galeri %U",
        "TryExec": "/opt/galeri/Galeri",
        "StartupNotify": "false",
        "Categories": "Productivity;Education"
      }
    },
    "snap": {
      "plugs": [
        "home",
        "x11",
        "unity7",
        "browser-support",
        "network",
        "gsettings",
        "opengl"
      ]
    }
  }
}
